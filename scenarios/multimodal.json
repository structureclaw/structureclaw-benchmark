[
  {
    "id": "image-beam-sketch",
    "description": "上传简支梁手绘草图，识别结构类型并分析",
    "category": "multimodal",
    "tags": ["multimodal", "beam", "image", "zh"],
    "message": "请根据这张图片识别结构类型，提取参数，然后进行静力分析",
    "locale": "zh",
    "maxRetries": 2,
    "attachments": [
      {
        "fileId": "bench-beam-sketch",
        "originalName": "beam-sketch.png",
        "relPath": "../../tests/llm-benchmark/fixtures/beam-sketch.png",
        "mimeType": "image/png"
      }
    ],
    "expect": {
      "skills": { "primary": "beam", "mayAlsoMatch": ["generic"] },
      "assertions": [
        { "type": "structural_type", "expected": "beam" },
        { "type": "skill_match", "primary": "beam", "mayAlsoMatch": ["generic"] },
        { "type": "has_model", "minNodes": 2, "minElements": 1 },
        { "type": "has_analysis" },
        { "type": "natural_language", "description": "The agent should identify the structure as a simply supported beam from the image and extract the span and load values" }
      ]
    }
  },
